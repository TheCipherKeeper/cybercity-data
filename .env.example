# Пример переменных окружения для cybercity-data.
# Без секретов. Копируй в .env и правь под себя; .env не коммитится.

# Адрес брокера Redpanda (Kafka-протокол). В compose — broker:9092.
BROKER_ADDR=broker:9092

# Пин контракта CONVENTIONS, на котором сервис работает (verification gate).
CONVENTIONS_PIN=v1

# Уровень логирования CLI (debug | info | warning | error).
DATA_LOG_LEVEL=info

# Воспроизводимая аллокация IP/CIDR (целое; без значения — случайная).
# DATA_SEED=42

# Выходной каталог артефактов сборки (по умолчанию ./build).
# DATA_OUT=build